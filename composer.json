{
    "name": "mayaram/laravel-browser-location",
    "description": "HTML5 browser geolocation package for Laravel with Livewire 4 support, GPS capture, reverse geocoding, maps, and API integration.",
    "keywords": [
        "Laravel Geolocation",
        "HTML5 Geolocation",
        "Livewire GPS",
        "Browser Location",
        "User Tracking Laravel",
        "Free Laravel Geolocation",
        "Laravel Geolocation API",
        "Laravel Geolocation Middleware",
        "Laravel Geolocation Service",
        "Laravel Geolocation Package",
        "Laravel Location Tracking",
        "Laravel Location API",
        "Laravel Location Middleware",
        "Laravel Location Service",
        "Laravel Location Package"
    ],
    "homepage": "https://github.com/mayaramyadav/laravel-browser-location",
    "license": "MIT",
    "authors": [
        {
            "name": "Mayaram",
            "email": "info@mayaram.in"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mayaram\\BrowserLocation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mayaram\\BrowserLocation\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mayaram\\BrowserLocation\\BrowserLocationServiceProvider"
            ],
            "aliases": {
                "BrowserGeocoder": "Mayaram\\BrowserLocation\\Facades\\Geocoder",
                "BrowserLocation": "Mayaram\\BrowserLocation\\Facades\\BrowserLocation"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
